{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account registration and system authorization roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user authentication ID." },
        "email": { "type": "string", "description": "User registration email address." },
        "role": { "type": "string", "enum": ["admin", "agent"], "description": "System role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Time of registration." }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Agent": {
      "title": "Agent",
      "description": "Agent detailed business profile and financial balances.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string", "description": "Matches authenticated User UID." },
        "name": { "type": "string", "description": "Full business or personal name of the agent." },
        "mobile": { "type": "string", "description": "Primary mobile wallet number of the agent." },
        "status": { "type": "string", "enum": ["pending", "approved", "suspended"], "description": "Approval state of the agent." },
        "walletBalance": { "type": "number", "description": "Current electronic wallet balance of the agent in BDT." },
        "referredBy": { "type": "string", "description": "Referral code of another agent." },
        "referralCode": { "type": "string", "description": "Unique agent identifier used for customer refer-a-friend promotions." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "name", "mobile", "status", "walletBalance", "referralCode", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer demographic profile registered by agents.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique auto-generated ID." },
        "name": { "type": "string", "description": "Customer name." },
        "mobile": { "type": "string", "description": "Unique customer phone number." },
        "registeredByAgentId": { "type": "string", "description": "UID of the registering agent." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "mobile", "registeredByAgentId", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Digital financial and operator operations generated by agents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentId": { "type": "string", "description": "UID of the executing agent." },
        "customerMobile": { "type": "string", "description": "Customer mobile involved in cash in, out, recharge, or bill pay." },
        "type": { "type": "string", "enum": ["deposit", "withdrawal", "recharge", "bill_pay"] },
        "operator": { "type": "string", "description": "Bangladeshi operators (Grameenphone, Banglalink, Robi, Airtel, Teletalk) for recharges." },
        "billType": { "type": "string", "description": "Type of utility bill (Electricity, Gas, Water, Internet)." },
        "amount": { "type": "number", "description": "Transaction volume in BDT." },
        "commissionEarned": { "type": "number", "description": "Amount earned from transaction (5% deposit, 3% withdrawal, 0% others)." },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "agentId", "customerMobile", "type", "amount", "commissionEarned", "status", "timestamp"]
    },
    "Commission": {
      "title": "Commission",
      "description": "Payout audit trail mapping to a transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentId": { "type": "string" },
        "transactionId": { "type": "string" },
        "amount": { "type": "number" },
        "rate": { "type": "number", "description": "Decimal percent rate applied." },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "agentId", "transactionId", "amount", "rate", "timestamp"]
    },
    "Referral": {
      "title": "Referral",
      "description": "Agent signup refer-a-friend records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "referrerAgentId": { "type": "string", "description": "UID of the agent who invited." },
        "referredAgentId": { "type": "string", "description": "UID of the newly registered agent." },
        "rewardAmount": { "type": "number", "description": "Payout of BDT 500 or 10% share." },
        "status": { "type": "string", "enum": ["pending_approval", "rewarded"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "referrerAgentId", "referredAgentId", "rewardAmount", "status", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Broadcast alerts and direct transaction notifications.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["broadcast", "individual"] },
        "recipientAgentId": { "type": "string", "description": "UID of the single recipient or null for broadcasts." },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "title", "body", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Base authenticated users roles."
    },
    "agents/{agentId}": {
      "schema": "Agent",
      "description": "Detailed agent dashboard database."
    },
    "customers/{customerId}": {
      "schema": "Customer",
      "description": "Agent client details."
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Agent cash operation histories."
    },
    "commissions/{commissionId}": {
      "schema": "Commission",
      "description": "Payout earnings track database."
    },
    "referrals/{referralId}": {
      "schema": "Referral",
      "description": "System sign up incentives database."
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Broadcast or direct messages."
    }
  }
}
